SERVER_ENV=development
SERVER_LOG_LEVEL=debug
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_SHUTDOWN_CLEANUP_PERIOD_SECONDS=15
SERVER_SHUTDOWN_GRACE_PERIOD_SECONDS=15

APP_NAME="mkp-test"
APP_TIMEZONE="Asia/Jakarta"
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOWED_HEADERS=Accept,Authorization,X-API-KEY,Content-Type
APP_CORS_ALLOWED_METHODS=GET,PUT,POST,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://127.0.0.1:3000
APP_CORS_ENABLE=true
APP_CORS_MAX_AGE_SECONDS=300
APP_RATE_LIMITER_ENABLE=true
APP_RATE_LIMITER_MAX_REQUESTS=100
APP_RATE_LIMITER_WINDOW_SECONDS=60
APP_API_KEY="your-super-secret-api-key-change-this-in-production"

JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRE_MIN=15
JWT_REFRESH_EXPIRE_MIN=10080

CACHE_REDIS_PRIMARY_HOST=redis
CACHE_REDIS_PRIMARY_PORT=6379
CACHE_REDIS_PRIMARY_PASSWORD=strongpassword
CACHE_REDIS_PRIMARY_DB=0
CACHE_REDIS_PRIMARY_TLS=false
CACHE_TTL=120

DB_POSTGRES_READ_HOST=postgres
DB_POSTGRES_READ_PORT=5432
DB_POSTGRES_READ_NAME="oil"
DB_POSTGRES_READ_USER="postgres"
DB_POSTGRES_READ_PASSWORD="password"
DB_POSTGRES_READ_TIMEZONE=UTC
DB_POSTGRES_READ_SSL_MODE=disable

DB_POSTGRES_WRITE_HOST=postgres
DB_POSTGRES_WRITE_PORT=5432
DB_POSTGRES_WRITE_NAME="oil"
DB_POSTGRES_WRITE_USER="postgres"
DB_POSTGRES_WRITE_PASSWORD="password"
DB_POSTGRES_WRITE_TIMEZONE=UTC
DB_POSTGRES_WRITE_SSL_MODE=disable

DB_POSTGRES_MAX_RETRY=3
DB_POSTGRES_RETRY_WAIT_TIME=5
DB_POSTGRES_MIGRATION_TABLE="oil_migrations"
DB_POSTGRES_AUTO_MIGRATE=false
DB_POSTGRES_PREFIX=""

EXTERNAL_OTEL_ENDPOINT="otel-collector:4317"
EXTERNAL_S3_API_ENDPOINT="http://localhost:9000"
EXTERNAL_S3_ACCESS_KEY_ID="123456789ABCD"
EXTERNAL_S3_SECRET_ACCESS_KEY="ABCDEFGHIJKLMN1234567890"
EXTERNAL_S3_BUCKET_NAME="oil-bucket"
EXTERNAL_S3_PUBLIC_DOMAIN="http://localhost:9000/"

KAFKA_BROKERS=kafka:9092
KAFKA_ENABLE=true
KAFKA_SASL_ENABLE=false
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""

KAFKA_CONSUMER_GROUP=mkp-test

KAFKA_TOPICS_NOTIFICATION=ticket.sold
KAFKA_TOPICS_REFUND=seat.restocked

KAFKA_NOTIFICATION_CONSUMER_GROUP=notification
KAFKA_NOTIFICATION_MAX_RETRY=2
KAFKA_NOTIFICATION_BACKOFF_DURATION=1

KAFKA_REFUND_CONSUMER_GROUP=refund
KAFKA_REFUND_MAX_RETRY=2
KAFKA_REFUND_BACKOFF_DURATION=1

ASYNQ_ENABLE=true
ASYNQ_CONCURRENCY=10

PAYMENT_MOCK_MODE=true
PAYMENT_WEBHOOK_SECRET="mock-webhook-secret-change-this"
PAYMENT_EXPIRE_MINUTES=10
PAYMENT_CALLBACK_BASE_URL="http://localhost:8080"
